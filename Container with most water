class Solution {
public:
    int maxArea(vector<int>& height) {
     int right=height.size()-1;
     int left =0;
     int max_a=0;
     while(left<right)
     {
        int curr_a = min(height[left], height[right])*(right-left);
        max_a=max(max_a, curr_a);
        if(height[left]<height[right])
        {
            left++;
        }
        else{
            right--;
        }
     }
     return max_a;
    }
};
